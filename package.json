{
  "name": "astro-sphere",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:network": "astro dev --host",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:network": "astro dev --host",
    "astro": "astro",
    "resume:pdf": "UV_CACHE_DIR=.cache/uv UV_TOOL_DIR=.cache/uv-tools uvx --from \"rendercv[full]==2.8\" rendercv render src/content/resume/Yieum_Yoon_CV.yaml --pdf-path ../../../public/resume.pdf --typst-path ../../../.cache/rendercv/resume.typ -nomd -nohtml -nopng",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "clsx": "^2.1.0",
    "prettier": "^3.4.2",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8"
  },
  "overrides": {
    "prettier": "^3.4.2"
  }
}
