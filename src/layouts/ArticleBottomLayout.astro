---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { getPostDateTime } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
};

// Get the requested entry
const { entry } = Astro.props;
const { Content } = await render(entry);

// Get the next and prev entries (modulo to wrap index)
const items = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => getPostDateTime(b.data).getTime() - getPostDateTime(a.data).getTime());
const index = items.findIndex((x) => x.id === entry.id);
const prev = items[(index - 1 + items.length) % items.length];
const next = items[(index + 1) % items.length];
const prevSlug = prev.id.replace(/\/index$/, "");
const nextSlug = next.id.replace(/\/index$/, "");
---

<div>
  <article>
    <Content />
  </article>

  <div class="border-t border-black/10 py-8 dark:border-white/15">
    <button
      id="load-comments"
      class="rounded border border-black/15 px-3 py-2 text-sm text-black/70 transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:border-white/20 dark:text-white/70 dark:hover:bg-white/10 dark:hover:text-white"
      type="button"
    >
      Load comments
    </button>
    <div id="comments" class="mt-6"></div>
  </div>

  <script>
    function initializeComments() {
      const button = document.getElementById("load-comments")
      const comments = document.getElementById("comments")

      if (!button || !comments || button.dataset.ready === "true") return

      button.dataset.ready = "true"
      button.addEventListener("click", () => {
        if (comments.querySelector("script")) return

        const script = document.createElement("script")
        script.src = "https://giscus.app/client.js"
        script.async = true
        script.crossOrigin = "anonymous"
        script.dataset.repo = "YieumYoon/YieumYoon.github.io"
        script.dataset.repoId = "R_kgDOMFPW6g"
        script.dataset.category = "Announcements"
        script.dataset.categoryId = "DIC_kwDOMFPW6s4Cf82h"
        script.dataset.mapping = "pathname"
        script.dataset.strict = "0"
        script.dataset.reactionsEnabled = "1"
        script.dataset.emitMetadata = "0"
        script.dataset.inputPosition = "top"
        script.dataset.theme = document.documentElement.classList.contains("dark")
          ? "noborder_dark"
          : "noborder_light"
        script.dataset.lang = "en"
        script.dataset.loading = "lazy"

        comments.appendChild(script)
        button.remove()
      })
    }

    document.addEventListener("astro:after-swap", initializeComments)
    initializeComments()
  </script>

  <div class="grid grid-cols-1 gap-6 border-t border-black/10 pt-8 dark:border-white/15 sm:grid-cols-2">
    <a
      href={`/blog/${prevSlug}`}
      class="group block"
    >
      <div class="space-y-2">
        <div class="text-sm uppercase text-black/45 dark:text-white/45">Previous</div>
        <div class="font-semibold text-black dark:text-white group-hover:underline group-hover:decoration-[.5px] group-hover:underline-offset-4">
          {prev.data.title}
        </div>
      </div>
    </a>
    <a
      href={`/blog/${nextSlug}`}
      class="group block sm:text-right"
    >
      <div class="space-y-2">
        <div class="text-sm uppercase text-black/45 dark:text-white/45">Next</div>
        <div class="font-semibold text-black dark:text-white group-hover:underline group-hover:decoration-[.5px] group-hover:underline-offset-4">
          {next.data.title}
        </div>
      </div>
    </a>
  </div>
</div>
