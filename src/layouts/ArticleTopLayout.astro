---
import type { CollectionEntry } from "astro:content"
import { formatPostDateTime, getPostDateTime, readingTime } from "@lib/utils"

type Props = {
  entry: CollectionEntry<"blog">
}

const { entry } = Astro.props
const { data, body } = entry
const { title, summary, date, time, timezone, updatedDate, updatedTime, updatedTimezone } = data
const publishedDateTime = getPostDateTime({ date, time, timezone }).toISOString()
const updatedDateTime = updatedDate
  ? getPostDateTime({
      date: updatedDate,
      time: updatedTime,
      timezone: updatedTimezone ?? timezone,
    }).toISOString()
  : undefined
---

<div>
  <a href="/blog" class="text-sm underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black/70 dark:text-white/70 underline-offset-2 blend">
    All posts
  </a>
  <div class="flex flex-wrap text-sm uppercase mt-12 gap-3 opacity-75">
    <time datetime={publishedDateTime} class="flex items-center gap-2">
      <svg class="size-5 stroke-current">
        <use href="/ui.svg#calendar"/>
      </svg>
      {formatPostDateTime({ date, time, timezone })}
    </time>
    {updatedDate && (
      <time datetime={updatedDateTime} class="flex items-center gap-2">
        <svg class="size-5 stroke-current">
          <use href="/ui.svg#refresh-cw"/>
        </svg>
        Updated {formatPostDateTime({
          date: updatedDate,
          time: updatedTime,
          timezone: updatedTimezone ?? timezone,
        })}
      </time>
    )}
    <div class="flex items-center gap-2">
      <svg class="size-5 stroke-current">
        <use href="/ui.svg#book-open"/>
      </svg>
      {readingTime(body ?? "")}
    </div>
  </div>
  <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
    {title}
  </h1>
  <div class="mt-1">
    {summary}
  </div>
</div>
