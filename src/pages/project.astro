---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { PROJECT } from "@consts"
import { getPostDateTime } from "@lib/utils"

const projectSlugs = new Set([
  "spot-fiducial-3dprint-generator",
  "00009-web-ar-camera-and-chanel-ice-link",
])

const projects = (await getCollection("blog"))
  .filter(post => !post.data.draft && projectSlugs.has(post.id))
  .sort((a, b) => getPostDateTime(b.data).getTime() - getPostDateTime(a.data).getTime())
---

<PageLayout title={PROJECT.TITLE} description={PROJECT.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      {PROJECT.TITLE}
    </div>
  </TopLayout>
  <BottomLayout>
    <section class="animate space-y-8">
      <div class="max-w-2xl space-y-3">
        <p class="text-sm text-black/50 dark:text-white/50">
          Built notes
        </p>
        <p class="leading-7 text-black/70 dark:text-white/70">
          직접 만들거나 기술을 뜯어보며 배운 프로젝트들을 모아두는 공간입니다. 작은 도구부터 웹, AR, 로보틱스 관련 실험까지 차근차근 정리해 나가고 있습니다.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {projects.map((project) => {
          const slug = project.id.replace(/\/index$/, "")
          return (
            <a href={`/blog/${slug}`} class="group flex h-full flex-col justify-between rounded-lg border border-black/10 p-5 transition-colors duration-300 ease-in-out hover:border-black/25 hover:bg-black/[0.02] dark:border-white/15 dark:hover:border-white/35 dark:hover:bg-white/[0.04]">
              <div class="space-y-3">
                <div class="flex flex-wrap gap-2">
                  {project.data.tags.slice(0, 3).map(tag => (
                    <span class="rounded-full bg-black/5 px-2 py-1 text-xs text-black/55 dark:bg-white/10 dark:text-white/60">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="font-semibold text-black group-hover:underline group-hover:decoration-[.5px] group-hover:underline-offset-4 dark:text-white">
                  {project.data.title}
                </h2>
                <p class="text-sm leading-6 text-black/65 dark:text-white/65">
                  {project.data.summary}
                </p>
              </div>
              <p class="mt-5 text-sm text-black/50 dark:text-white/50">
                Read project note
              </p>
            </a>
          )
        })}
      </div>
    </section>
  </BottomLayout>
</PageLayout>
