# Installed as /etc/pagescms/pagescms.env with mode 0640.
BASE_URL=https://your-oracle-node.your-tailnet.ts.net
BETTER_AUTH_SECRET=replace-with-a-random-hex-value

DATABASE_URL=postgresql://pagescms:replace-with-a-random-hex-value@127.0.0.1:5432/pagescms
POSTGRES_MAX_CONNECTIONS=5

GITHUB_APP_ID=replace-me
GITHUB_APP_NAME=yieum-local-blog-cms
GITHUB_APP_CLIENT_ID=replace-me
GITHUB_APP_CLIENT_SECRET=replace-me
GITHUB_APP_PRIVATE_KEY_FILE=/etc/pagescms/github-app.pem

# Webhooks stay disabled for this Tailscale-only deployment.
GITHUB_APP_WEBHOOK_SECRET=replace-with-another-random-hex-value
